FROM golang:1.26-alpine AS builder

RUN apk add --no-cache ca-certificates && \
    adduser -D -H -u 65532 -g '' -s /sbin/nologin nenya && \
    mkdir -p /tmp/etc && \
    echo "nenya:x:65532:65532::/home/nenya:/sbin/nologin" > /tmp/etc/passwd && \
    echo "nenya:x:65532:" > /tmp/etc/group

WORKDIR /src

COPY go.mod go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod go mod download

COPY . .

ARG TARGETARCH
ARG VERSION=dev
ARG COMMIT=unknown
ARG BUILDTIME=unknown
RUN CGO_ENABLED=0 GOOS=linux GOARCH="${TARGETARCH:-amd64}" go build \
  -ldflags="-s -w -X nenya/internal/version.Version=${VERSION} -X nenya/internal/version.Commit=${COMMIT} -X nenya/internal/version.BuildTime=${BUILDTIME}" \
  -o nenya ./cmd/nenya

FROM scratch

COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY --from=builder /tmp/etc/passwd /tmp/etc/group /etc/
COPY --from=builder /src/nenya /nenya

USER nenya:nenya

# ARG PORT=8080 sets default for build, ENV makes it available at runtime
# Note: Binary defaults to :8080 via config.ApplyDefaults(), not this ENV
ARG PORT=8080
ENV PORT=${PORT}
EXPOSE ${PORT}

ENTRYPOINT ["/nenya"]
