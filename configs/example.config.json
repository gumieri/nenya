{
  "server": {
    "listen_addr": ":8080",
    "max_body_bytes": 10485760
  },

  "governance": {
    "ratelimit_max_tpm": 250000,
    "ratelimit_max_rpm": 15,
    "truncation_strategy": "middle-out",
    "keep_first_percent": 15.0,
    "keep_last_percent": 25.0

    // Enable TF-IDF relevance-scored truncation for Tier 3 (payloads above context_hard_limit).
    // When set, content is split into blocks (paragraphs + code fences) and scored by relevance
    // to the user's query terms. Blocks with the lowest scores are discarded first.
    // If the pruned payload falls below context_soft_limit, the engine (Ollama) call is skipped entirely.
    // Options: "" (disabled, use middle-out), "prior_messages" (use previous user messages as query),
    // "self" (use first 500 runes of the massive message as query).
    // "tfidf_query_source": "prior_messages",

    // Retryable upstream HTTP status codes. WARNING: setting this field REPLACES the built-in
    // defaults entirely. You must include all codes you want retryable. Built-in defaults:
    // [429, 500, 502, 503, 504]. Example to also retry on 400 and 413:
    // "retryable_status_codes": [429, 500, 502, 503, 504, 400, 413]
  },

  "security_filter": {
    "enabled": true,
    "redaction_label": "[REDACTED]",
    // When true, if the engine (Ollama/cloud) is unreachable, skip summarization
    // and forward the original payload. Allows Nenya to work without Ollama.
    "skip_on_engine_failure": true,
    // Engine can be a string (agent name) or an inline object.
    // String form: references an agent's model list as a fallback chain.
    // Object form: directly specifies provider/model (backward compatible).
    "engine": {
      "provider": "ollama",
      "model": "qwen2.5-coder:7b",
      "system_prompt_file": "./prompts/privacy_filter.md",
      "timeout_seconds": 60
    }
  },

  "prefix_cache": {
    "enabled": true,
    "pin_system_first": true,
    "stable_tools": true,
    "skip_redaction_on_system": true
  },

  "compaction": {
    "enabled": true,
    "json_minify": true,
    "collapse_blank_lines": true,
    "trim_trailing_whitespace": true,
    "normalize_line_endings": true
  },

  "window": {
    "enabled": false,
    "mode": "summarize",
    "active_messages": 6,
    "trigger_ratio": 0.8,
    "summary_max_runes": 4000,
    "max_context": 128000,
    "engine": {
      "provider": "ollama",
      "model": "qwen2.5-coder:7b",
      "system_prompt_file": "./prompts/summarizer.md",
      "timeout_seconds": 60
    }
  },

  "response_cache": {
    // Master toggle. Disabled by default.
    "enabled": false,
    // Maximum cached responses (LRU eviction)
    "max_entries": 512,
    // Maximum size per cached response (1 MB)
    "max_entry_bytes": 1048576,
    // Time-to-live for cached entries (1 hour)
    "ttl_seconds": 3600,
    // Background eviction sweep interval (5 minutes)
    "evict_every_seconds": 300,
    // HTTP header to bypass cache (any non-empty value forces bypass)
    "force_refresh_header": "x-nenya-cache-force-refresh"
  },

  "agents": {
    // Agents can also be used as engines for security_filter and window.
    // Reference them by name: "engine": "summarizer"
    "summarizer": {
      "strategy": "fallback",
      "system_prompt": "You are a data privacy filter. Remove or replace sensitive information with [REDACTED].",
      "models": [
        { "provider": "ollama", "model": "qwen2.5-coder:7b" },
        { "provider": "deepseek", "model": "deepseek-chat" }
      ]
    },
    "build": {
      "strategy": "fallback",
      "cooldown_seconds": 60,
      // Circuit breaker: consecutive failures before tripping
      "failure_threshold": 5,
      // Circuit breaker: consecutive successes in HalfOpen to recover
      "success_threshold": 1,
      // Cap on retry attempts per request (0 = unlimited)
      "max_retries": 0,
      // Optional: Model Context Protocol (MCP) server integration.
      // MCP tools are exposed to the LLM as OpenAI function tools.
      // When the LLM responds with tool_calls for MCP tools, Nenya executes
      // them locally and re-sends with results (multi-turn loop).
      "mcp": {
        "servers": ["mempalace"],
        "max_iterations": 10,
        "auto_search": true,
        "auto_save": true
      },
      "models": [
        "gemini-3.1-flash-lite-preview",
        "gemini-2.5-flash",
        // Deferred provider expansion: all providers offering this model
        // (discovery catalog first, then ModelRegistry fallback)
        "deepseek-v4-flash",
        // Provider-only selector: all discovered models from this provider
        {"provider": "zai"},
        // Regex selector: all models matching the pattern across all providers
        {"model_rgx": "^claude-3\\.5-.*$"}
      ]
    },
    "plan": {
      "strategy": "fallback",
      "cooldown_seconds": 60,
      "models": [
        "glm-5-turbo"
      ]
    },
    "free-llm": {
      "strategy": "fallback",
      "cooldown_seconds": 60,
      "models": [
        "nemotron-3-super",
        "qwen-3.6-plus",
        "minimax-m2.5"
      ]
    },
    // Agent using provider-only selector: all models from a provider
    "all-deepseek": {
      "strategy": "round-robin",
      "models": [
        {"provider": "deepseek"}
      ]
    },
    // Agent using regex model selector: all models matching the pattern
    "all-flash-models": {
      "strategy": "round-robin",
      "models": [
        {"model_rgx": ".*flash.*"}
      ]
    },
    // Agent using provider regex: all models from matching providers
    "all-free-models": {
      "strategy": "fallback",
      "models": [
        {"provider_rgx": ".*_free"}
      ]
    }
  },

  // MCP servers: connect Nenya to external MCP servers via HTTP+SSE proxy.
  // Tools from these servers are injected into LLM requests for agents that reference them.
  // "mcp_servers": {
  //   "mempalace": {
  //     "url": "http://localhost:6060",
  //     "timeout": 30
  //   }
  // },

  "providers": {
    "gemini": {
      "url": "https://generativelanguage.googleapis.com/v1beta/openai/chat/completions",
      "auth_style": "bearer+x-goog"
    },
    "deepseek": {
      "url": "https://api.deepseek.com/chat/completions",
      "auth_style": "bearer"
    },
    "zai": {
      "url": "https://api.z.ai/v1/chat/completions",
      "auth_style": "bearer"
     },
     "ollama": {
       "url": "http://127.0.0.1:11434/v1/chat/completions",
       "auth_style": "none"
     }
   }
}
