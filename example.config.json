{
  "server": {
    "listen_addr": ":8080",
    "max_body_bytes": 10485760
  },
  
  // Global context truncation and rate limiting rules
  "governance": {
    "ratelimit_max_tpm": 250000,
    "ratelimit_max_rpm": 15,
    "context_soft_limit": 4000,
    "context_hard_limit": 24000,
    "truncation_strategy": "middle-out",
    "keep_first_percent": 15.0,
    "keep_last_percent": 25.0
  },

  // Security and Filtering Pipeline (Where your local Ollama operates)
  "security_filter": {
    "enabled": true,
    "redaction_label": "[REDACTED]",
    "engine": {
      "url": "http://127.0.0.1:11434/api/generate",
      "model": "qwen2.5-coder:7b",
      "api_format": "ollama",
      "system_prompt_file": "./prompts/privacy_filter.md",
      "timeout_seconds": 600
    }
  },

  // Prefix caching optimizations
  "prefix_cache": {
    "enabled": true,
    "pin_system_first": true,
    "stable_tools": true,
    "skip_redaction_on_system": true
  },

  // Text compaction (size reduction before sending upstream)
  "compaction": {
    "enabled": true,
    "json_minify": true,
    "collapse_blank_lines": true,
    "trim_trailing_whitespace": true,
    "normalize_line_endings": true
  },

  // Context window management (summarize/truncate old messages)
  "window": {
    "enabled": false,
    "mode": "summarize",
    "active_messages": 6,
    "trigger_ratio": 0.8,
    "summary_max_runes": 4000,
    "max_context": 128000,
    "engine": {
      "url": "http://127.0.0.1:11434/api/generate",
      "model": "qwen2.5-coder:7b",
      "api_format": "ollama",
      "system_prompt_file": "./prompts/summarizer.md",
      "timeout_seconds": 600
    }
  },

  // Agents – define fallback chains for specific model prefixes
  "agents": {
    "claude": {
      "strategy": "fallback",
      "cooldown_seconds": 60,
      "models": [
        { "provider": "openai", "model": "gpt-4o", "max_context": 128000 },
        { "provider": "zai", "model": "glm-4", "max_context": 128000 }
      ]
    }
  },

  // Providers – override or extend built-in provider definitions
  "providers": {
    "openai": {
      "url": "https://api.openai.com/v1/chat/completions",
      "auth_style": "bearer",
      "route_prefixes": ["gpt-", "o3-", "o4-"]
    },
    "zai": {
      "url": "https://api.z.ai/v1/chat/completions",
      "auth_style": "bearer",
      "route_prefixes": ["glm-"]
    }
  }
}